# Copy this file to .streamlit/secrets.toml only in your local machine.
# Do not commit real credentials.

JPQ_SHEET_ID = "your_google_sheet_id"
JPQ_USE_LOCAL_FALLBACK = "0"

# Recommended for Streamlit Cloud
JPQ_GOOGLE_SERVICE_ACCOUNT_JSON = "{\"type\":\"service_account\",\"project_id\":\"...\",\"private_key\":\"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n\",\"client_email\":\"...\",\"token_uri\":\"https://oauth2.googleapis.com/token\"}"

# Local-only alternative
# JPQ_GOOGLE_SERVICE_ACCOUNT_FILE = "/absolute/path/to/service-account.json"
