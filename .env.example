# Google Sheets source
JPQ_SHEET_ID=your_google_sheet_id
JPQ_USE_LOCAL_FALLBACK=0

# Choose ONE credential option:
# 1) Path to service account JSON file
JPQ_GOOGLE_SERVICE_ACCOUNT_FILE=/absolute/path/to/service-account.json

# 2) JSON string (for CI/deploy), leave empty if using file path
JPQ_GOOGLE_SERVICE_ACCOUNT_JSON=
